    console.log("[VIDENTE] Iniciando " + v);
    
    const createHUD = () => {
        let h = document.getElementById('v-hud');
        if (!h) {
            h = document.createElement('div');
            h.id = 'v-hud';
            h.style = "position:fixed; top:5%; left:50%; transform:translateX(-50%); z-index:9999999; background:rgba(0,0,0,0.9); color:#0f0; padding:15px; border:2px solid #0f0; border-radius:10px; font-family:monospace; text-align:center; min-width:250px; box-shadow:0 0 30px #0f0; pointer-events:none;";
            document.documentElement.appendChild(h);
        }
        return h;
    };

    const hud = createHUD();

    const parseSpribe = (obj) => {
        try {
            if (obj && obj.message) {
                const bytes = Object.values(obj.message);
                const str = String.fromCharCode(...bytes.slice(0, 100));
                
                // [NOVO] Heurística v1.7 - Detecção de Assinatura de Pacote
                if (str.includes("mines") || bytes.length > 500) {
                    console.log("[VIDENTE] Pacote de Dados Spribe (" + bytes.length + " bytes)");
                    
                    // Procurar por blocos de 25 bytes (Grid)
                    // No Spribe, o grid real costuma vir em sequências que não começam com tags baixas
                    let candidates = [];
                    for (let i = 0; i < bytes.length - 25; i++) {
                        let chunk = bytes.slice(i, i+25);
                        // Filtro: apenas 0 (diamante) e 1 (bomba) ou similar
                        if (chunk.every(x => x === 0 || x === 1)) {
                            let n = chunk.reduce((a,b) => a+b, 0);
                            if (n > 0 && n < 25) candidates.push(chunk);
                        }
                    }

                    if (candidates.length > 0) {
                        // Pegar o último candidato (geralmente o estado mais recente)
                        let grid = candidates[candidates.length - 1];
                        let bombs = [];
                        grid.forEach((v, idx) => { if(v === 1) bombs.push(idx); });
                        return { grid: bombs };
                    }
                }
            }
        } catch(e) {}
        return {};
    };

    const showPrediction = (win, msg, color, bombs = null) => {
        hud.style.display = 'block';
        hud.style.borderColor = color;
        hud.style.boxShadow = `0 0 30px ${color}`;
        
        let gridHtml = '';
        if (bombs && Array.isArray(bombs) && bombs.length > 0) {
            gridHtml = '<div style="display:grid; grid-template-columns:repeat(5, 30px); gap:4px; margin-top:10px; justify-content:center;">';
            for (let i = 0; i < 25; i++) {
                const isBomb = bombs.includes(i);
                gridHtml += `<div style="width:30px; height:30px; background:${isBomb ? '#f00' : '#0f02'}; border:1px solid ${isBomb ? '#f004' : '#0f04'}; border-radius:4px; font-size:12px; line-height:30px; color:#fff;">${isBomb ? '💣' : '💎'}</div>`;
            }
            gridHtml += '</div>';
            msg = "🔍 PROBABILIDADE ALTA 🔍";
        }

        hud.innerHTML = `
            <div style="font-size:9px; color:#0f0; margin-bottom:5px;">SISTEMA VIDENTE v1.7 ACTIVE</div>
            <div style="font-size:16px; font-weight:bold; color:${color};">${msg}</div>
            ${win > 0 ? `<div style="font-size:20px; color:#0f0; margin:10px 0;">+ R$ ${win.toFixed(2)}</div>` : ''}
            ${gridHtml}
            <div style="font-size:8px; opacity:0.5; margin-top:10px;">AGUARDANDO NOVA RODADA...</div>
        `;
        
        if (!bombs) setTimeout(() => { hud.style.display = 'none'; }, 5000);
    };

    // Interceptar Fetch
    const oldFetch = window.fetch;
    window.fetch = async (...args) => {
        const res = await oldFetch(...args);
        const url = typeof args[0] === 'string' ? args[0] : args[0].url;
        if (url.includes('Spin') || url.includes('Action') || url.includes('api/send') || url.includes('bet')) {
            const clone = res.clone();
            clone.json().then(data => {
                const parsed = parseSpribe(data);
                const dt = parsed.dt || parsed.result || parsed.data || parsed;
                
                const bombs = dt.grid || dt.b || (dt.data && dt.data.grid);
                if (bombs) showPrediction(0, "", "#ff0", bombs);
                
                const win = parseFloat(dt.aw || dt.win || dt.amount || dt.total_win || dt.winAmount || 0);
                if (win > 0) showPrediction(win, "💰 GANHOU! 💰", "#0f0");
                else if (win === 0 && !bombs && (url.includes('Spin') || url.includes('Action'))) showPrediction(0, "✖️ SEM GANHO ✖️", "#f00");
            }).catch(() => {});
        }
        return res;
    };

    // WebSocket (Para Spribe real-time)
    const OWS = window.WebSocket;
    window.WebSocket = function(u, p) {
        const ws = new OWS(u, p);
        ws.addEventListener('message', (e) => {
            try {
                const d = JSON.parse(e.data);
                const p = parseSpribe(d);
                const b = p.grid || p.b || (p.data && p.data.grid);
                if (b) showPrediction(0, "", "#ff0", b);
            } catch(ex) {}
        });
        return ws;
    };
    Object.assign(window.WebSocket, OWS);

})();
</script><div id="app"></div><script nomodule>!function(){var e=document,t=e.createElement("script");if(!("noModule"in t)&&"onbeforeload"in t){var n=!1;e.addEventListener("beforeload",(function(e){if(e.target===t)n=!0;else if(!e.target.hasAttribute("nomodule")||!n)return;e.preventDefault()}),!0),t.type="module",t.src=".",e.head.appendChild(t),t.remove()}}();</script><script nomodule crossorigin id="vite-legacy-polyfill" src="/assets/polyfills-legacy-BW7b0pCl.js"></script><script nomodule crossorigin id="vite-legacy-entry" data-src="/assets/index-legacy-DBVNBxGT.js">System.import(document.getElementById('vite-legacy-entry').getAttribute('data-src'))</script></body></html>

